<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ TÍNH ĐIỆN TIÊU THỤ CĂN HỘ"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#1565C0"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhập số lượng thiết bị và số giờ sử dụng mỗi ngày. Bỏ trống nếu không có."
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="12dp"/>

        <!-- Kỳ tính -->
        <RadioGroup
            android:id="@+id/rgPeriod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="8dp">
            <RadioButton
                android:id="@+id/rbMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Tháng (30 ngày)"/>
            <RadioButton
                android:id="@+id/rbQuarter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Quý (90 ngày)"/>
        </RadioGroup>

        <!-- Tiêu đề cột -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Thiết bị"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Số lượng"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Giờ/ngày"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Các hàng thiết bị: thêm động từ MainActivity -->
        <LinearLayout
            android:id="@+id/deviceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <!-- Thiết bị khác -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thiết bị khác (tùy chọn)"
            android:textStyle="bold"
            android:paddingTop="12dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/etOtherWatt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="Công suất (W)"
                android:inputType="numberDecimal"/>
            <EditText
                android:id="@+id/etOtherQty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="SL"
                android:inputType="number"/>
            <EditText
                android:id="@+id/etOtherHours"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Giờ"
                android:inputType="numberDecimal"/>
        </LinearLayout>

        <!-- Số điện thực tế -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Số điện THỰC TẾ trên hóa đơn (kWh)"
            android:textStyle="bold"
            android:paddingTop="16dp"/>
        <EditText
            android:id="@+id/etActualKwh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="VD: 250"
            android:inputType="numberDecimal"/>

        <Button
            android:id="@+id/btnCalc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="🔍 TÍNH TOÁN &amp; KẾT LUẬN"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="14sp"
            android:textIsSelectable="true"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
